{
	"name": "hegemony",
	"version": "1.0.0",
	"private": true,
	"workspaces": [
		"server",
		"client",
		"packages/simple-styled"
	],
	"scripts": {
		"build:client": "bun run --filter client build",
		"dev:client": "bun run --elide-lines 0 --no-clear-screen --install fallback --env-file .env --env-file .env.local --filter client dev",
		"dev:server": "bun run --elide-lines 0 --no-clear-screen --install fallback --env-file .env --env-file .env.local --filter server dev",
		"dev": "concurrently --restart-tries=-1 --restart-after=1000 --names 'server ,client ,' --c 'green,cyan' 'bun run dev:server' 'bun run dev:client'",
		"generate:shared-types": "bun run ./scripts/generate-shared-types.ts",
		"lint:report": "oxlint",
		"lint:types": "tsgo --noEmit",
		"lint": "oxlint --fix && oxfmt",
		"preview:client": "bun run --filter client preview",
		"test": "vitest run"
	},
	"dependencies": {
		"@emotion/react": "^11.11.4",
		"@emotion/styled": "^11.11.5",
		"@tanstack/react-query": "^5.51.21",
		"@types/lodash": "^4.17.7",
		"dotenv": "^16.4.5",
		"lodash": "^4.17.21",
		"mobx": "^6.13.1",
		"mobx-react": "^9.1.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"@types/react": "^18.3.3",
		"@types/react-dom": "^18.3.0",
		"@typescript/native-preview": "^7.0.0-dev.20260507.1",
		"@vitejs/plugin-react": "^6.0.1",
		"concurrently": "^9.2.1",
		"lefthook": "^2.1.6",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"sass-embedded": "^1.96.0",
		"typescript": "^5.5.2",
		"vite": "^8.0.11",
		"vitest": "^2.0.5"
	}
}
